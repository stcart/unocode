DATABASE_URL="postgresql://praktika:praktika@localhost:5432/praktika?schema=public"
PORT=3001
CORS_ORIGIN="http://localhost:3000"
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"

# Email (optional — without SMTP, notifications are logged to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Docker Compose overrides DATABASE_URL to postgres:5432 automatically.
